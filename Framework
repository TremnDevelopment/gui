--[[
    Custom GUI Library
    ------------------
    A lightweight, draggable settings-style GUI for Roblox with:
      - Tabs, with a built-in "Settings" tab (active by default)
      - Sections
      - Toggles, Sliders, Buttons, Dropdowns, Color Pickers
      - Toast notifications with a customizable screen position
      - Live-customizable accent color (applies everywhere instantly)

    HOW TO USE:
    1. Put this in a LocalScript (e.g. StarterPlayerScripts), or require it
       as a ModuleScript from ReplicatedStorage.
    2. Call Library:CreateWindow(...) to make a window.
    3. Call Window:CreateTab(...) to add tabs, then :CreateSection(...) on
       the tab to add a panel, then add toggles/sliders/etc to the section.
    4. Each element takes a callback function — that's where YOU plug in
       your own feature logic. Placeholder functions are provided in
       Example_Usage.lua (they just print to output).

    A "Settings" tab is created automatically and is selected by default.
    It contains:
      - Notification Position (dropdown: which corner toasts appear in)
      - UI Color (R/G/B sliders that recolor the whole GUI's accent live)
]]

local Players = game:GetService("Players")
local TweenService = game:GetService("TweenService")
local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer
local PlayerGui = LocalPlayer:WaitForChild("PlayerGui")

local Library = {}
Library.__index = Library

-- ===== THEME =====
-- Static base colors. `Colors.Accent` (below) is the one live-customizable
-- color; everything that uses it stays in sync when it changes.
local Theme = {
    Background   = Color3.fromRGB(24, 24, 28),
    Section      = Color3.fromRGB(32, 32, 38),
    Accent       = Color3.fromRGB(90, 120, 255),
    Text         = Color3.fromRGB(235, 235, 240),
    SubText      = Color3.fromRGB(160, 160, 170),
    ToggleOff    = Color3.fromRGB(55, 55, 62),
    Stroke       = Color3.fromRGB(50, 50, 58),
}

-- Live, mutable colors. Elements read Colors.Accent (not Theme.Accent) so
-- that changing it at runtime is reflected the next time anything reads it.
local Colors = {
    Accent = Theme.Accent,
}

-- Elements that need to visually update the instant the accent color
-- changes (not just next time they're interacted with) register a
-- listener here via onAccentChanged(fn).
local AccentListeners = {}
local function onAccentChanged(fn)
    table.insert(AccentListeners, fn)
end

-- ===== HELPERS =====
local function tween(obj, props, time)
    time = time or 0.15
    TweenService:Create(obj, TweenInfo.new(time, Enum.EasingStyle.Quad), props):Play()
end

local function corner(parent, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = parent
    return c
end

local function stroke(parent, color, thickness)
    local s = Instance.new("UIStroke")
    s.Color = color or Theme.Stroke
    s.Thickness = thickness or 1
    s.Parent = parent
    return s
end

